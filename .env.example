# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ─── SePay Configuration ───────────────────────────────────────────────────────
# Legacy Firebase-based webhooks (old method)
SEPAY_WEBHOOK_TOKEN="replace_with_a_long_random_string"

# NEW: HMAC-SHA256 Webhook Secret (from SePay Dashboard)
# Copy từ SePay Dashboard → Webhooks → Secret Key
# Used for HMAC-SHA256 signature verification
SEPAY_WEBHOOK_SECRET="your_sepay_webhook_secret_from_dashboard"

# SePay API Key (for webhook authorization)
# Get from SePay Dashboard → Webhooks → API Key
SEPAY_API_KEY="your_sepay_api_key_from_dashboard"
SEPAY_WEBHOOK_TOKEN="your_sepay_api_key_from_dashboard"

# Payment code prefix: Only process webhooks with this prefix
# Example: HMATH (payment code format: HMATH + studentname + randomcode)
PAYMENT_CODE_PREFIX="HMATH"

# ─── MySQL Database Configuration (NEW) ───────────────────────────────────────
# Connection details for SePay webhook database
# Create database: mysql -u root -p < db-schema.sql
DB_HOST="localhost"
DB_USER="db_user"
DB_PASS="your_secure_password"
DB_NAME="sepay_webhook"

# ─── Server Configuration ──────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
